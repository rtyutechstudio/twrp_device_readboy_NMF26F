# Android fstab for recovery init (minimal)
/dev/block/bootdevice/by-name/system    /system    ext4    ro,barrier=1                wait
/dev/block/bootdevice/by-name/cache     /cache     ext4    nosuid,nodev,barrier=1      wait,check,formattable
/dev/block/bootdevice/by-name/userdata  /data      ext4    nosuid,nodev,noauto_da_alloc wait,check,encryptable=footer,length=-16384,formattable
/dev/block/bootdevice/by-name/misc      /misc      emmc    defaults                     defaults